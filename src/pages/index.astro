---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import Capabilities from '../components/sections/Capabilities.astro';
import RequestPipeline from '../components/interactive/RequestPipeline.tsx';
import CaseStudies from '../components/sections/CaseStudies.astro';
import Process from '../components/sections/Process.astro';
import DiagnosticForm from '../components/interactive/DiagnosticForm.tsx';
import FAQ from '../components/sections/FAQ.astro';
import Footer from '../components/sections/Footer.astro';
---

<Layout
  title="DarkoSync | Sistemas a Medida, Inteligencia Artificial y E-commerce"
  description="Diseñamos sistemas críticos robustos a medida, integraciones de IA aplicada a negocios y plataformas de e-commerce preparadas para crecer en Bolivia sin caídas ni fricciones."
>
  <!-- Navigation Header -->
  <Header />

  <!-- Main Narrative Flow -->
  <main id="main-content" tabindex="-1" class="w-full scroll-mt-24 outline-none">
    <!-- Hero: Promesa de Valor -->
    <Hero />

    <!-- Problem: La Realidad Operativa (Tensión) -->
    <Problem />

    <!-- Capabilities: Especialidades (Bento Grid) -->
    <Capabilities />

    <!-- Interactive Pipeline Demo -->
    <section id="pipeline" class="relative py-24 md:py-32">
      <div class="mx-auto max-w-7xl px-6 md:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16 md:mb-24">
          <p class="text-sm font-semibold tracking-wider text-[var(--color-accent)] uppercase">
            Ingeniería Visible
          </p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl md:text-5xl leading-tight">
            Transparencia técnica de extremo a extremo.
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-[var(--color-text-muted)]">
            Observá cómo fluyen las peticiones, se autentican los accesos y escala el cómputo en nuestra simulación de infraestructura interactiva.
          </p>
        </div>
        
        <!-- React Live Request Pipeline Island -->
        <RequestPipeline client:visible />
      </div>
    </section>

    <!-- Case Studies & Portfolio -->
    <CaseStudies />

    <!-- The Method / Process -->
    <Process />

    <!-- Interactive Conversion Form -->
    <section id="diagnostico" class="relative py-24 md:py-32 bg-[rgba(50,255,126,0.01)] border-t border-[rgba(255,255,255,0.04)]">
      <div class="mx-auto max-w-7xl px-6 md:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16 md:mb-24">
          <p class="text-sm font-semibold tracking-wider text-[var(--color-accent)] uppercase">
            Comenzar Hoy
          </p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl md:text-5xl leading-tight">
            Evaluemos tu proyecto.
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-[var(--color-text-muted)]">
            Respondé este breve cuestionario sobre tus dolores operativos. Analizaremos tu caso y te propondremos soluciones de inmediato vía WhatsApp.
          </p>
        </div>

        <!-- React Project Diagnostic Form Island -->
        <DiagnosticForm client:load />
        <noscript><p class="mt-6 text-center text-sm text-[var(--color-text-muted)]">Para solicitar un diagnóstico sin JavaScript, escribinos a darkosync@gmail.com.</p></noscript>
      </div>
    </section>

    <!-- FAQ Accordion -->
    <FAQ />
  </main>

  <!-- Footer -->
  <Footer />
</Layout>

<style is:global>
  /* Global animations for interactive components */
  @keyframes dash {
    to {
      stroke-dashoffset: -200;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }

  /* Support for users with prefers-reduced-motion settings */
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
    
    .animate-pulse,
    .animate-ping,
    [class*="animate-"] {
      animation: none !important;
      transform: none !important;
    }
    
    path[stroke="url(#glow-line)"] {
      animation: none !important;
      stroke-dasharray: none !important;
      stroke: var(--color-accent) !important;
      opacity: 0.4;
    }
  }
</style>
