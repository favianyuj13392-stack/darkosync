---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import EvidenceStrip from '../components/sections/EvidenceStrip.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import Problem from '../components/sections/Problem.astro';
import Capabilities from '../components/sections/Capabilities.astro';
import EditorialBreak from '../components/sections/EditorialBreak.astro';
import SalesFlow from '../components/interactive/SalesFlow.tsx';
import Process from '../components/sections/Process.astro';
import DiagnosticForm from '../components/interactive/DiagnosticForm.tsx';
import FAQ from '../components/sections/FAQ.astro';
import Footer from '../components/sections/Footer.astro';
---

<Layout
  title="DarkoSync | Software a medida · Bolivia"
  description="Convertimos operaciones manuales en sistemas que tu empresa puede controlar y escalar. Diseño de software de gestión, ventas digitales y automatización."
>
  <Header />

  <main id="main-content" tabindex="-1" class="w-full scroll-mt-24 outline-none">
    <Hero />
    <EvidenceStrip />
    <CaseStudies />
    <Problem />
    <Capabilities />
    <EditorialBreak />
    
    <section id="flujo" class="relative py-24 md:py-32 ds-reveal">
      <div class="mx-auto max-w-7xl px-6 md:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16 md:mb-24">
          <h2 class="text-3xl font-extrabold tracking-tight text-[var(--ds-text)] sm:text-4xl md:text-5xl leading-tight">
            Así se mueve una venta en un negocio con DarkoSync
          </h2>
        </div>
        <SalesFlow client:visible />
      </div>
    </section>

    <Process />

    <section id="diagnostico" class="relative py-24 md:py-32 bg-[var(--ds-bg)] border-t border-[var(--ds-border)] ds-reveal">
      <div class="mx-auto max-w-7xl px-6 md:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16 md:mb-24">
          <p class="text-sm font-semibold tracking-wider text-[var(--ds-muted)] uppercase">
            Diagnóstico operativo
          </p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-[var(--ds-text)] sm:text-4xl md:text-5xl leading-tight">
            Contanos cómo opera tu negocio hoy.
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-[var(--ds-muted)]">
            Respondé este formulario y en menos de 24 horas te enviamos una propuesta por WhatsApp.
          </p>
        </div>

        <DiagnosticForm client:load />
        <noscript><p class="mt-6 text-center text-sm text-[var(--ds-muted)]">Para solicitar un diagnóstico sin JavaScript, escribinos a darkosync@gmail.com.</p></noscript>
      </div>
    </section>

    <FAQ />
  </main>

  <Footer />
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>
