---
// src/components/sections/EvidenceStrip.astro
---

<section class="w-full border-y border-[var(--ds-border)] bg-[var(--ds-surface)] py-4 ds-reveal">
  <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-4 px-6 md:flex-row md:items-center md:px-8">
    
    <div class="flex flex-wrap gap-x-8 gap-y-4">
      <div class="flex flex-col">
        <span class="text-xs text-[var(--ds-muted)] uppercase tracking-wider">Proyectos entregados</span>
        <span class="text-sm font-medium text-[var(--ds-text)]">[N] &rarr;</span>
      </div>
      <div class="flex flex-col">
        <span class="text-xs text-[var(--ds-muted)] uppercase tracking-wider">Clientes activos</span>
        <span class="text-sm font-medium text-[var(--ds-text)]">[N] &rarr;</span>
      </div>
      <div class="flex flex-col">
        <span class="text-xs text-[var(--ds-muted)] uppercase tracking-wider">Tiempo promedio de entrega</span>
        <span class="text-sm font-medium text-[var(--ds-text)]">[N] semanas &rarr;</span>
      </div>
    </div>

    <div class="text-[10px] text-[var(--ds-muted)] uppercase tracking-wider">
      * Cifras en validación
    </div>
    
  </div>
</section>
