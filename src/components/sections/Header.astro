---
// src/components/sections/Header.astro
---

<header class="fixed top-0 left-0 z-50 w-full border-b border-[var(--ds-border)] bg-[#0A0C0F]/80 backdrop-blur-md transition-all duration-300">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 md:px-8">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-3 font-semibold tracking-wider text-xl text-white select-none" aria-label="DarkoSync, Inicio">
      <div class="relative h-10 w-10 overflow-hidden">
        <img src="/assets/LogoMark.png" alt="DarkoSync Logo" class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105" />
      </div>
      <span class="font-bold tracking-wide text-white transition-colors duration-300 group-hover:text-[var(--ds-accent)]" style="font-family: var(--font-display);">
        DARKOSYNC
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav aria-label="Navegación principal" class="hidden md:flex items-center gap-8">
      <a href="#capacidades" class="relative py-2 text-sm font-medium text-[var(--ds-muted)] hover:text-white transition-colors duration-300 nav-link">Servicios</a>
      <a href="#casos" class="relative py-2 text-sm font-medium text-[var(--ds-muted)] hover:text-white transition-colors duration-300 nav-link">Casos</a>
      <a href="#proceso" class="relative py-2 text-sm font-medium text-[var(--ds-muted)] hover:text-white transition-colors duration-300 nav-link">Proceso</a>
      <a href="#faq" class="relative py-2 text-sm font-medium text-[var(--ds-muted)] hover:text-white transition-colors duration-300 nav-link">Preguntas</a>
    </nav>

    <!-- CTA Button -->
    <div class="hidden md:flex items-center">
      <a href="#diagnostico" class="group relative flex items-center justify-center gap-2 overflow-hidden rounded-lg border border-[var(--ds-accent)] bg-transparent px-5 py-2.5 text-sm font-medium text-white transition-all duration-300 hover:bg-[var(--ds-accent)] hover:text-black">
        <span class="relative z-10">Solicitar diagnóstico</span>
        <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 relative z-10">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.22 5.03a.75.75 0 111.06-1.06l5.5 5.5a.75.75 0 010 1.06l-5.5 5.5a.75.75 0 11-1.06-1.06l4.168-4.17H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="flex flex-col gap-1.5 p-2 md:hidden" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="mobile-drawer">
      <span class="h-0.5 w-6 rounded bg-white transition-all duration-300 burger-line"></span>
      <span class="h-0.5 w-6 rounded bg-white transition-all duration-300 burger-line"></span>
      <span class="h-0.5 w-6 rounded bg-white transition-all duration-300 burger-line"></span>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-drawer" class="fixed inset-x-0 top-20 z-40 hidden border-b border-[var(--ds-border)] bg-[#0A0C0F]/95 px-6 py-8 backdrop-blur-lg transition-all duration-300">
    <nav aria-label="Navegación móvil" class="flex flex-col gap-6 text-center">
      <a href="#capacidades" class="mobile-nav-link text-lg font-medium text-[var(--ds-muted)] hover:text-white">Servicios</a>
      <a href="#casos" class="mobile-nav-link text-lg font-medium text-[var(--ds-muted)] hover:text-white">Casos</a>
      <a href="#proceso" class="mobile-nav-link text-lg font-medium text-[var(--ds-muted)] hover:text-white">Proceso</a>
      <a href="#faq" class="mobile-nav-link text-lg font-medium text-[var(--ds-muted)] hover:text-white">Preguntas</a>
      <a href="#diagnostico" class="mobile-nav-link mt-4 flex items-center justify-center gap-2 rounded-lg bg-[var(--ds-accent)] px-5 py-3 text-base font-semibold text-black transition-all">
        <span>Solicitar diagnóstico</span>
        <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.22 5.03a.75.75 0 111.06-1.06l5.5 5.5a.75.75 0 010 1.06l-5.5 5.5a.75.75 0 11-1.06-1.06l4.168-4.17H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  /* Underline link animation */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--ds-accent);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease-out;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Hamburger transition */
  button[aria-expanded="true"] .burger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  button[aria-expanded="true"] .burger-line:nth-child(2) {
    opacity: 0;
  }
  button[aria-expanded="true"] .burger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const drawer = document.getElementById('mobile-drawer');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');

  if (menuBtn && drawer) {
    const closeMenu = (returnFocus = false) => {
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.setAttribute('aria-label', 'Abrir menú de navegación');
      drawer.classList.add('hidden');
      if (returnFocus) menuBtn.focus();
    };

    const openMenu = () => {
      menuBtn.setAttribute('aria-expanded', 'true');
      menuBtn.setAttribute('aria-label', 'Cerrar menú de navegación');
      drawer.classList.remove('hidden');
      window.requestAnimationFrame(() => navLinks[0]?.focus());
    };

    menuBtn.addEventListener('click', () => {
      const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
      if (expanded) closeMenu();
      else openMenu();
    });

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape' && menuBtn.getAttribute('aria-expanded') === 'true') {
        closeMenu(true);
      }
    });

    navLinks.forEach(link => link.addEventListener('click', () => closeMenu()));
  }

  // Scroll transparency effect
  window.addEventListener('scroll', () => {
    const header = document.querySelector('header');
    if (header) {
      if (window.scrollY > 50) {
        header.classList.add('py-4', 'bg-[#0A0C0F]/95');
        header.classList.remove('py-6', 'bg-[#0A0C0F]/80');
      } else {
        header.classList.add('py-6', 'bg-[#0A0C0F]/80');
        header.classList.remove('py-4', 'bg-[#0A0C0F]/95');
      }
    }
  });
</script>

