---
// src/components/sections/Capabilities.astro
---

<section id="capacidades" class="relative py-24 md:py-32 bg-[var(--ds-surface)] border-y border-[var(--ds-border)] ds-reveal">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-extrabold tracking-tight text-[var(--ds-text)] sm:text-4xl md:text-5xl leading-tight font-display">
        Lo que construimos
      </h2>
    </div>

    <!-- Tabs UI -->
    <div class="max-w-4xl mx-auto">
      
      <!-- Tab List -->
      <div class="flex flex-wrap gap-2 justify-center mb-12 border-b border-[var(--ds-border)] pb-4" role="tablist" aria-label="Especialidades">
        <button id="tab-1" type="button" role="tab" aria-selected="true" aria-controls="panel-1" class="tab-btn px-6 py-2 text-sm font-medium rounded-full transition-colors bg-[var(--ds-accent)] text-black focus:outline-none focus:ring-2 focus:ring-[var(--ds-accent)] focus:ring-offset-2 focus:ring-offset-[var(--ds-bg)]">
          Gestión interna
        </button>
        <button id="tab-2" type="button" role="tab" aria-selected="false" aria-controls="panel-2" class="tab-btn px-6 py-2 text-sm font-medium rounded-full transition-colors text-[var(--ds-muted)] hover:text-white focus:outline-none focus:ring-2 focus:ring-[var(--ds-accent)] focus:ring-offset-2 focus:ring-offset-[var(--ds-bg)]">
          Ventas digitales
        </button>
        <button id="tab-3" type="button" role="tab" aria-selected="false" aria-controls="panel-3" class="tab-btn px-6 py-2 text-sm font-medium rounded-full transition-colors text-[var(--ds-muted)] hover:text-white focus:outline-none focus:ring-2 focus:ring-[var(--ds-accent)] focus:ring-offset-2 focus:ring-offset-[var(--ds-bg)]">
          Automatización
        </button>
      </div>

      <!-- Tab Panels -->
      <div class="relative min-h-[300px]">
        
        <!-- Panel 1 -->
        <div id="panel-1" role="tabpanel" tabindex="0" aria-labelledby="tab-1" class="tab-panel absolute top-0 left-0 w-full transition-all duration-500 ease-out opacity-100 translate-x-0">
          <h3 class="text-2xl font-bold text-[var(--ds-text)] font-display mb-4">Sistemas que ordenan la casa</h3>
          <p class="text-[var(--ds-muted)] leading-relaxed mb-4">
            Construimos software privado para que controles qué entra, qué sale y quién hace qué dentro de tu empresa. Sin depender de licencias por usuario y adaptado exactamente a tus reglas de negocio.
          </p>
          <p class="text-[var(--ds-muted)] leading-relaxed mb-6">
            Ideal para operaciones logísticas, clínicas o fábricas que necesitan un sistema central y único.
          </p>
          <ul class="flex flex-col gap-3">
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Control de inventarios y almacenes
            </li>
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Gestión de accesos, roles y personal
            </li>
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Reportes financieros y operativos en tiempo real
            </li>
          </ul>
        </div>

        <!-- Panel 2 -->
        <div id="panel-2" role="tabpanel" tabindex="0" aria-labelledby="tab-2" class="tab-panel absolute top-0 left-0 w-full transition-all duration-500 ease-out opacity-0 translate-x-8 invisible pointer-events-none">
          <h3 class="text-2xl font-bold text-[var(--ds-text)] font-display mb-4">Canales de venta que no duermen</h3>
          <p class="text-[var(--ds-muted)] leading-relaxed mb-4">
            Diseñamos plataformas de comercio electrónico y catálogos transaccionales rápidos y confiables. Tus clientes podrán comprar desde su celular a cualquier hora, sin fricción y con métodos de pago locales integrados.
          </p>
          <p class="text-[var(--ds-muted)] leading-relaxed mb-6">
            Tu tienda conectada directamente a tu inventario real para que nunca vendas lo que no tienes.
          </p>
          <ul class="flex flex-col gap-3">
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Tiendas en línea de alta velocidad
            </li>
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Pasarelas de pago y facturación integradas
            </li>
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Catálogos digitales autoadministrables
            </li>
          </ul>
        </div>

        <!-- Panel 3 -->
        <div id="panel-3" role="tabpanel" tabindex="0" aria-labelledby="tab-3" class="tab-panel absolute top-0 left-0 w-full transition-all duration-500 ease-out opacity-0 translate-x-8 invisible pointer-events-none">
          <h3 class="text-2xl font-bold text-[var(--ds-text)] font-display mb-4">Máquinas haciendo trabajo de máquinas</h3>
          <p class="text-[var(--ds-muted)] leading-relaxed mb-4">
            Conectamos tus sistemas actuales para que hablen entre sí. Si hoy necesitas descargar un Excel de un sistema para subirlo a otro, nosotros creamos el puente invisible que lo hace solo.
          </p>
          <p class="text-[var(--ds-muted)] leading-relaxed mb-6">
            Liberá a tu equipo de tareas repetitivas para que se concentren en lo que realmente aporta valor.
          </p>
          <ul class="flex flex-col gap-3">
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Sincronización entre sistemas y CRMs
            </li>
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Notificaciones automáticas por WhatsApp o correo
            </li>
            <li class="flex items-start gap-2 text-sm text-[var(--ds-text)]">
              <span class="text-[var(--ds-accent)]">&rarr;</span> Automatización de facturas y cobros recurrentes
            </li>
          </ul>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    .tab-panel {
      transition: none !important;
      transform: none !important;
    }
  }
</style>

<script>
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      // Reset all buttons
      tabBtns.forEach(b => {
        b.setAttribute('aria-selected', 'false');
        b.classList.remove('bg-[var(--ds-accent)]', 'text-black');
        b.classList.add('text-[var(--ds-muted)]');
      });
      // Activate clicked button
      btn.setAttribute('aria-selected', 'true');
      btn.classList.add('bg-[var(--ds-accent)]', 'text-black');
      btn.classList.remove('text-[var(--ds-muted)]');

      // Hide all panels
      tabPanels.forEach(panel => {
        panel.classList.add('opacity-0', 'invisible', 'pointer-events-none');
        
        // Reset transform based on motion preference
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          panel.classList.add('translate-x-8');
          panel.classList.remove('translate-x-0');
        }
      });

      // Show target panel
      const targetPanel = document.getElementById(btn.getAttribute('aria-controls') || '');
      if (targetPanel) {
        targetPanel.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          targetPanel.classList.remove('translate-x-8');
          targetPanel.classList.add('translate-x-0');
        }
      }
    });
  });
</script>
